{
  "about": "Presidio-hardened Oracle Cloud (oci) baseline for ScoutSuite. Fail-closed: high-impact identity/storage controls are forced to 'danger'. Rule filenames are verified against the pinned upstream ScoutSuite version declared in requirements.lock; CI validates every referenced rule against policy/oci.rules.txt before release.",
  "rules": {
    "identity-password-policy-minimum-length.json": [{ "enabled": true, "level": "danger" }],
    "identity-password-policy-no-lowercase-required.json": [{ "enabled": true, "level": "warning" }],
    "identity-password-policy-no-number-required.json": [{ "enabled": true, "level": "warning" }],
    "identity-password-policy-no-symbol-required.json": [{ "enabled": true, "level": "warning" }],
    "identity-password-policy-no-uppercase-required.json": [{ "enabled": true, "level": "warning" }],
    "identity-policy-affects-user.json": [{ "enabled": true, "level": "warning" }],
    "identity-user-with-multiple-api-keys.json": [{ "enabled": true, "level": "warning" }],
    "kms-no-key-rotation.json": [{ "enabled": true, "level": "warning" }],
    "objectstorage-bucket-lacking-kms-encryption.json": [{ "enabled": true, "level": "warning" }],
    "objectstorage-public-bucket.json": [{ "enabled": true, "level": "danger" }]
  }
}
