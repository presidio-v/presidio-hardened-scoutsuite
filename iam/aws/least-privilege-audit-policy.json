{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PresidioScoutSupplementalReadOnly",
      "Effect": "Allow",
      "Action": [
        "account:GetAlternateContact",
        "access-analyzer:List*",
        "access-analyzer:Get*",
        "cloudtrail:GetEventSelectors",
        "cloudtrail:ListTags",
        "config:Describe*",
        "config:Get*",
        "ec2:GetEbsEncryptionByDefault",
        "guardduty:Get*",
        "guardduty:List*",
        "macie2:GetMacieSession",
        "s3:GetBucketPublicAccessBlock",
        "s3:GetAccountPublicAccessBlock",
        "securityhub:Get*",
        "securityhub:Describe*",
        "sns:GetSubscriptionAttributes"
      ],
      "Resource": "*"
    },
    {
      "Sid": "PresidioScoutDenyAnyWrite",
      "Effect": "Deny",
      "NotAction": [
        "account:Get*",
        "access-analyzer:Get*",
        "access-analyzer:List*",
        "acm:Describe*",
        "acm:List*",
        "cloudformation:Describe*",
        "cloudformation:Get*",
        "cloudformation:List*",
        "cloudtrail:Describe*",
        "cloudtrail:Get*",
        "cloudtrail:List*",
        "cloudwatch:Describe*",
        "cloudwatch:Get*",
        "cloudwatch:List*",
        "config:Describe*",
        "config:Get*",
        "config:List*",
        "dynamodb:Describe*",
        "dynamodb:List*",
        "ec2:Describe*",
        "ec2:Get*",
        "elasticloadbalancing:Describe*",
        "guardduty:Get*",
        "guardduty:List*",
        "iam:Get*",
        "iam:List*",
        "iam:Generate*",
        "kms:Describe*",
        "kms:Get*",
        "kms:List*",
        "lambda:Get*",
        "lambda:List*",
        "logs:Describe*",
        "logs:Get*",
        "logs:List*",
        "rds:Describe*",
        "rds:List*",
        "redshift:Describe*",
        "route53:Get*",
        "route53:List*",
        "s3:Get*",
        "s3:List*",
        "secretsmanager:Describe*",
        "secretsmanager:List*",
        "securityhub:Describe*",
        "securityhub:Get*",
        "securityhub:List*",
        "ses:Get*",
        "ses:List*",
        "sns:Get*",
        "sns:List*",
        "sqs:Get*",
        "sqs:List*",
        "sts:Get*",
        "tag:Get*"
      ],
      "Resource": "*"
    }
  ]
}
