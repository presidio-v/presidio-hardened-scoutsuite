# Example org config for presidio-scout. Copy to `.presidio-scout.toml` in your
# repo root. `[defaults]` applies to every run; `--profile <name>` overlays a
# `[profiles.<name>]` table; explicit CLI flags always win over both.
# Validate with: presidio-scout-policy validate

[defaults]
provider = "aws"
require-short-lived-creds = true
fail-on-secret = true
fail-on-remote-ref = true
waivers = "security/scout-waivers.json"

# Strict gate for scheduled/CI audits: block on any danger finding and emit SARIF.
[profiles.nightly]
fail-on-finding = "danger"
sarif = "scoutsuite-report/results.sarif"
attest = "scoutsuite-report/run.intoto.json"

# Looser local-dev profile.
[profiles.dev]
require-short-lived-creds = false
fail-on-finding = "warning"

# Extra secret patterns, applied in addition to the built-in redactors during
# report redaction. Each entry is a regex string or a { name, pattern } table.
# An uncompilable regex fails `presidio-scout-policy validate`.
[redaction]
extra-patterns = [
  { name = "internal_token", pattern = "INT-[A-Z0-9]{20}" },
  "GHX-[a-z0-9]{16}",
]

# Compose the ruleset from a bundled provider baseline instead of hand-writing
# one. Used automatically (unless you pass --ruleset / --no-baseline). Every rule
# named here must exist in the pinned ScoutSuite's manifest, or validation fails.
[baseline]
base = "aws"

[baseline.set-level]            # raise/lower (or add) a rule's severity
"s3-bucket-no-versioning.json" = "danger"

[baseline.disable]              # drop rules from the base baseline
rules = ["ec2-default-security-group-with-rules.json"]

# Notification sink for presidio-scout-notify (see the README).
[sinks.prod-slack]
type = "slack"
url = "https://hooks.slack.com/services/REPLACE/ME"
